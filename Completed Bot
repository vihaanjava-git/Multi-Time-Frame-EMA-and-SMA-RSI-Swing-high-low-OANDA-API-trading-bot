trades_closed = False
def is_market_open():
  twenty = 20 #winter hours, for summer daylight savings, add 1
  twenty_two =22 #winter hours, for summer daylight savings, add 1
  day_td = datetime.now(timezone.utc).weekday()
  current_hour = datetime.now(timezone.utc).hour
  current_minute = datetime.now(timezone.utc).minute
  if 0 <= day_td <= 3:
    return True
  if day_td == 5:
    return False
  if day_td == 4: #if today is friday
    if current_hour < twenty: #if hour on clock is less than 21
      return True
    elif current_hour == twenty:
      if current_minute < 30:
        return True
      if current_minute >= 30:
        if trades_closed == False:
          try:
            exit_all_trades()
            trades_closed = True
            return False
          except:
            return False
        else:
          pass
    else:
      return False
  if day_td == 6:
    if current_hour > twenty_two:
      return True
    if current_hour == twenty_two:
      if current_minute >= 0:
        return True
      else:
        return False
    else:
      return True
  else:
    return False

def cooldown_period():
    trades = []
    try:
        params = {"instrument": oanda_ticker, "state": "CLOSED", "count": 1}
        cooldownr = trades_endpoints.TradesList(accountID=oanda_account_id, params=params)
        client.request(cooldownr)
        trades = cooldownr.response.get("trades", [])
    except Exception as e:
        print(f"Cooldown check error: {e}")
        return True
    if not trades:
        return True
    close_time = datetime.fromisoformat(trades[0]["closeTime"][:26] + "+00:00")
    return datetime.now(timezone.utc) - close_time > timedelta(hours=24)



    ema_initial_calc = clse[0:(window + 1)]
    ema_initial = sum(ema_initial_calc) / len(ema_initial_calc)
    ema_y.append(ema_initial)
    while window + 1 < i:
        alpha = 2 / (window_initial + 1)
        ty_price = clse[window + 1]
        yy_ema = ema_y[-1]
        ema_t = (ty_price * alpha) + (yy_ema * (1 - alpha))
        ema_y.append(ema_t)
